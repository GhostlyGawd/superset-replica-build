{
  "name": "@swarm/sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server-entry.ts",
      "default": "./src/server-entry.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts ./src/server-entry.ts --outdir ./dist --target node --packages external",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@swarm/core-engine": "workspace:*",
    "@swarm/shared": "workspace:*",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
