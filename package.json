{
  "name": "swarm-monorepo",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=22"
  },
  "workspaces": ["apps/*", "packages/*"],
  "trustedDependencies": ["@homebridge/node-pty-prebuilt-multiarch"],
  "overrides": {
    "@types/node": "25.9.3"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --concurrency=2",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/bun": "latest",
    "turbo": "^2.3.0",
    "typescript": "^5.7.3"
  }
}
