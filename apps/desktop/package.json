{
  "name": "@swarm/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "node ./scripts/dev-electron.mjs",
    "build": "vite build && bun build ./src/main.ts --outfile=./dist/main.js --target node --format esm --external electron && bun build ./src/preload.ts --outfile=./dist/preload.cjs --target node --format cjs --external electron",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./src",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@swarm/core-engine": "workspace:*",
    "@swarm/db": "workspace:*",
    "@swarm/host": "workspace:*",
    "@swarm/shared": "workspace:*",
    "@swarm/sync": "workspace:*",
    "@swarm/ui": "workspace:*",
    "@trpc/client": "^11.17.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@swarm/pty-supervisor": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "electron": "^42.4.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.16"
  }
}
